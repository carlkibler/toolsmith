{
  "name": "toolsmith",
  "version": "0.1.0",
  "description": "Portable hash-anchored edit primitives for agent harnesses.",
  "type": "module",
  "private": true,
  "exports": {
    ".": "./src/index.js"
  },
  "scripts": {
    "test": "node --test",
    "check": "node --check src/*.js bin/*.mjs && node --test",
    "install:harnesses": "./scripts/install-harnesses.sh",
    "test:harnesses": "./scripts/test-harnesses.sh",
    "test:harnesses:live": "./scripts/test-harnesses.sh --live"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "typebox": "^1.1.34"
  },
  "bin": {
    "toolsmith": "./bin/toolsmith.mjs",
    "toolsmith-mcp": "./bin/toolsmith-mcp.mjs"
  },
  "pi": {
    "extensions": [
      "./extensions"
    ]
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*"
  },
  "files": [
    "bin/",
    "docs/",
    "extensions/",
    "scripts/",
    "src/",
    "AGENTS.md",
    "CLAUDE.md",
    "README.md"
  ]
}
